{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Preview HTML Document",
            "type": "process",
            "command": "powershell",
            "args": [
                "-Command",
                "Start-Process \"${file}\""
            ],
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Run Python File",
            "type": "process",
            "command": "python",
            "args": [
                "${file}"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
